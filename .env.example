# Copy this file to `.env` and adjust as needed. `.env` is gitignored — never commit real secrets.
# Docker Compose reads this file automatically for the values below marked "compose".

# ---------------------------------------------------------------------------
# Docker Compose — Postgres (host ports remapped to avoid colliding with the
# system Postgres on 5432 and other local projects on 5433)
# ---------------------------------------------------------------------------
POSTGRES_USER=syncflow
POSTGRES_PASSWORD=syncflow_dev_password
POSTGRES_DB=syncflow
POSTGRES_PORT=5434

# ---------------------------------------------------------------------------
# Docker Compose — Redis (host port remapped to avoid colliding with the
# convoychat project's Redis on 6379)
# ---------------------------------------------------------------------------
REDIS_PORT=6380

# ---------------------------------------------------------------------------
# apps/server — connection strings (point at the host-mapped ports above,
# since the server runs on the host via `pnpm dev`, not inside Docker)
# ---------------------------------------------------------------------------
NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://syncflow:syncflow_dev_password@localhost:5434/syncflow
REDIS_URL=redis://localhost:6380

# ---------------------------------------------------------------------------
# apps/server — auth
# ---------------------------------------------------------------------------
# Generate real secrets with: openssl rand -base64 48
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
COOKIE_DOMAIN=localhost

# ---------------------------------------------------------------------------
# apps/server — CORS (must match the web app's origin)
# ---------------------------------------------------------------------------
CORS_ORIGIN=http://localhost:3000

# ---------------------------------------------------------------------------
# apps/web — public URLs the browser talks to
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
