# Copy to `.env.production` (gitignored — never commit real secrets) and fill in real
# values. Used only by docker-compose.prod.yml:
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build
#
# DATABASE_URL/REDIS_URL aren't listed here — docker-compose.prod.yml builds them itself
# from the values below, pointed at the `postgres`/`redis` service names on the private
# Docker network, not localhost.

# ---------------------------------------------------------------------------
# Postgres
# ---------------------------------------------------------------------------
POSTGRES_USER=syncflow
POSTGRES_PASSWORD=
POSTGRES_DB=syncflow

# ---------------------------------------------------------------------------
# apps/server — auth. Generate real secrets with: openssl rand -base64 48
# ---------------------------------------------------------------------------
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
# The real domain the auth cookie is scoped to (not "localhost" in prod).
COOKIE_DOMAIN=

# ---------------------------------------------------------------------------
# apps/server — CORS. The origin the browser-hosted frontend is served from.
# ---------------------------------------------------------------------------
CORS_ORIGIN=

# ---------------------------------------------------------------------------
# apps/server — logging (pino level: fatal|error|warn|info|debug|trace|silent)
# ---------------------------------------------------------------------------
LOG_LEVEL=info
