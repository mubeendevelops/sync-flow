{
  "name": "server",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e ../../.env -- tsx watch src/server.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "dotenv -e ../../.env -- node-pg-migrate up -j sql",
    "migrate:down": "dotenv -e ../../.env -- node-pg-migrate down -j sql",
    "migrate:new": "node-pg-migrate create -j sql",
    "seed": "dotenv -e ../../.env -- tsx src/seed.ts"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "@sync-flow/crdt": "workspace:*",
    "argon2": "^0.41.1",
    "cookie": "^2.0.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.13.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "redis": "^6.1.0",
    "socket.io": "^4.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^7.2.0",
    "dotenv-cli": "^8.0.0",
    "node-pg-migrate": "^7.9.1",
    "pino-pretty": "^13.1.3",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2",
    "tsc-alias": "^1.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.10"
  }
}
